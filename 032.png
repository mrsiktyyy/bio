        <script type="text/javascript">
            document.addEventListener('DOMContentLoaded', function() {
                // Находим все элементы с классом "disable-right-click"
                var elements = document.querySelectorAll('.disable-right-click');

                // Функция для отключения контекстного меню и перетаскивания
                function disableContextMenuAndDrag(e) {
                    e.preventDefault();
                }

                	// Применяем функцию к найденным элементам
                	elements.forEach(function(element) {
                    element.addEventListener('contextmenu', disableContextMenuAndDrag);

                    // Отключаем перетаскивание элемента
                    element.draggable = false;

                    // Отключаем выделение текста на элементе
                    element.addEventListener('selectstart', function(e) {
                        e.preventDefault();
                    });

                    // Отключаем перетаскивание изображения в некоторых браузерах
                    element.addEventListener('dragstart', function(e) {
                        e.preventDefault();
                    });
                });
            });
        </script>
