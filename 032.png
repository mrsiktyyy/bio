	border-radius: 25px;
	padding: 5px 25px;
	font-size: 18px!important;
	font-weight:500;
    }
    .btn-dwl:hover {
    color: #fff;
	background: #9d7bdb!important}
@media screen and (max-width: 768px) {
   .btn-dwl {
    font-size: 16px!important;
