/*скрыть желтый фон объявлений*/
ins {background-color: #FFFFFF!important;}


/* хлебные крошки */
.breadcrumbs-area {
	background: #E7EBF4;
    height: 35px;
    line-height: 32px;
    
}

#breadcrumbs {
    list-style: none;	
	overflow: hidden;
	font-size: .9em!important;
	text-align: left;
	margin: 0;
	
}
  
#breadcrumbs li {
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.4em;
}

#breadcrumbs li.separator {
	margin-left: 0.3em;
	color: gray;
	
}

#breadcrumbs li.item-current .bread-current {
    color:#002338;
	font-weight: 400;
}

.filter-button {
        color: #000;
        background: #F7F8FB;
        border: #a5a8af 1px solid;
        border-radius: 25px;
        padding: 7px 18px;
        margin: 0 2.5px 5px 2.5px;
        font-size: 13px!important;
    }
    .active {
        color: #fff;
        background: #000;
        border-radius: 25px;
        padding: 7px 18px;
        border: #000 1px solid;
    }
    
    .filter-button:hover {
        color: #FFF;
        background: #000;
        border: #000 1px solid;}
        
    /* Стили для поп-ап окна */
._ssd-popup {
  display: none; /* По умолчанию скрыто */
  position: fixed;
  z-index: 999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5); /* Тень */
}

._ssd-popup-ads {
    text-align:center;
    margin:15px auto;
}

._ssd-popup-content {
    background-color: #fff;
    margin: 5% auto;
    padding: 35px;
    border-radius: 10px;
    height: 650px;
    width: 580px;
    text-align: center;
    position: relative;
}

._ssd-close {
  position: absolute;
  top: 0px;
  right: 15px;
  color: #3D7BF5;
  font-size: 40px;
  cursor: pointer;
}

._ssd-container {
  width: 100%;
  background-color: #E7EBF4;
  border: 1px solid #E7EBF4;
  border-radius: 25px;
  height: 20px;
  margin-top: 10px;
}

._ssd-bar {
  width: 0;
  height: 100%;
  background-color: #002338;
  border-radius: 25px;
  transition: width 1s linear;
}

/*кнопка СКАЧАТЬ*/
.btn1 a{
    display:block;
    margin:20px auto;
}
.download_btn1 {
    background-color:#fff!important;
    color:#002338!important;
    width: 230px;
    text-align:center;
    border:1px #002338 solid!important;
    border-radius:4px;
    font-size: 1.15em;
    cursor: pointer;
}
.download_btn1:hover {
    background-color:#002338!important;
    color:#fff!important;
}


/*кнопка СКАЧАТЬ в POPUPe*/
#download_btn2 {
    max-width: 230px;
    margin:0 auto;
    border-radius:4px;
    font-size: 1.15em;
}

#menu-main-menu {
    display:flex!important;
    align-items: center!important;
}

.container__tg {
    animation: pulse 0.8s infinite;
}

.telegram-button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background-color: #0088cc;
    color: #fff;
    text-decoration: none;
    padding: 7px 20px;
    border-radius: 5px;
    font-size: 16px;
}

.telegram-button:hover {
    transform: scale(1.05);
    background-color: #002338;
    color: #fff;
}

.telegram-button img {
    width: 24px;
    height: 24px;
    margin-right: 10px;
}

.call-to-action {
    margin-top: px;
    color: #000;
    font-size: 14px;
}
@keyframes pulse {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.07);
    }
    100% {
        transform: scale(1);
    }
}

/*проверка ip*/
.welcome-pt-overlay {
opacity: 0;
visibility: hidden;
position: fixed;
top: 0;
left: 0;
right: 0;
bottom: 0;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
background-color: rgba(0, 0, 0, .5);
z-index: 8000;
transition: all 0.3s;
}
.welcome-pt-message {
opacity: 0;
visibility: hidden;
width: 100%;
max-width: 500px;
position: fixed;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
z-index: 8001;
box-shadow: 0px 11px 15px -7px rgb(0 0 0 / 20%), 0px 24px 38px 3px rgb(0 0 0 / 14%), 0px 9px 46px 8px rgb(0 0 0 / 12%);
text-align: center;
padding: 30px;
margin: 16px 0;
border-radius: 4px;
background-color: #fff;
box-sizing: border-box;
transition: all 0.3s;
}
@media (max-width: 532px) {
.welcome-pt-message {
width: auto;
left: 16px;
right: 16px;
transform: translate(0, -50%);
}
}
.is-active.welcome-pt-overlay,
.is-active .welcome-pt-message {
opacity: 1;
visibility: visible;
}

/* Custom styles here */
.site-form-title {
text-align: center;
margin-bottom: 20px;
font-size: 36px;
line-height: 40px;
font-weight: 300;
color: #3d424b;
}
@media (max-width: 532px) {
.site-form-title {
margin-bottom: 14px;
font-size: 30px;
line-height: 36px;
}
}
.site-form-text {
font-size: 16px;
line-height: 20px;
margin-top: 0;
}
.site-form-buttons {
display: flex;
justify-content: center;
margin-top: 32px;
}
.welcome-pt-close {
height: 50px;
line-height: 50px;
min-width: 180px;
padding: 0 32px;
border: none;
font-size: 16px;
white-space: nowrap;
color: #fff;
cursor: pointer;
text-decoration: none;
border-radius: 5px;
background-color: #0836ff;
transition: all 0.3s ease 0s;
display: inline-block;
margin: 0;
text-transform: uppercase;
letter-spacing: 0.02em;
box-sizing: border-box;
text-align: center;
box-shadow: 0px 3px 1px -2px rgb(0 0 0 / 20%), 0px 2px 2px 0px rgb(0 0 0 / 14%), 0px 1px 5px 0px rgb(0 0 0 / 12%);
}
.welcome-pt-close:hover {
background-color: #0435c9;
}</style>
</head>

