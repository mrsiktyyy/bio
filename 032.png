<script>
//<![CDATA[
document.addEventListener("DOMContentLoaded", function () {
  const popup = document.getElementById("_ssd-popup");
  const downloadBtn = document.querySelector(".download_btn1");
  const closeBtn = document.querySelector("._ssd-close");
  const download2Btn = document.getElementById("download_btn2");
  const progressBar = document.querySelector("._ssd-bar");
  const progressBarContainer = document.querySelector("._ssd-container");
  const timerText = document.getElementById("_ssd-timer-text");
  let counter = 10;
  let intervalId;

  // Открываем поп-ап при клике на кнопку "Скачать"
  downloadBtn.addEventListener("click", function () {
    popup.style.display = "block";
    startTimer(); // Запускаем таймер
  });

  // Закрываем поп-ап при клике на крестик
  closeBtn.onclick = function () {
    closePopup();
  };

  // Закрываем поп-ап при клике вне его
  window.onclick = function (event) {
    if (event.target == popup) {
      closePopup();
    }
  };

  // Функция закрытия поп-апа
  function closePopup() {
    popup.style.display = "none";
    resetTimer(); // Сбрасываем таймер и прогресс-бар
  }

  // Функция запуска таймера
  function startTimer() {
    counter = 10;
    let progress = 0;
    const step = 100 / counter; // Шаг прогресс-бара

    // Показываем таймер и прогресс-бар
    timerText.style.display = "block";
    progressBarContainer.style.display = "block"; // Показываем контейнер прогресс-бара
    download2Btn.style.display = "none";
    progressBar.style.width = "0"; // Сбрасываем прогресс-бар

    intervalId = setInterval(function () {
      counter--;
      progress += step;
      progressBar.style.width = `${progress}%`; // Обновляем ширину прогресс-бара
      timerText.innerHTML = `Загрузка начнется через ${counter} секунд...`;

      if (counter <= 0) {
        clearInterval(intervalId); // Останавливаем таймер
        timerText.style.display = "none"; // Скрываем таймер
        progressBarContainer.style.display = "none"; // Скрываем прогресс-бар
        download2Btn.style.display = "block"; // Показываем кнопку "Скачать2"
      }
    }, 1000);
  }

  // Функция сброса таймера и прогресс-бара
  function resetTimer() {
    clearInterval(intervalId);
    progressBar.style.width = "0";
    timerText.innerHTML = "Загрузка начнется через 10 секунд...";
    timerText.style.display = "block";
    progressBarContainer.style.display = "block"; // Возвращаем контейнер для следующего запуска
    download2Btn.style.display = "none";
  }
});


//]]>
</script>	

